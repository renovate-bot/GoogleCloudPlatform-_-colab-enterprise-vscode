{
  "name": "workbench-notebooks",
  "publisher": "googlecloudtools",
  "displayName": "Workbench Notebooks",
  "description": "Connect notebooks to Workbench instances.",
  "icon": "icon.png",
  "version": "0.1.1",
  "preview": true,
  "pricing": "Free",
  "homepage": "https://github.com/GoogleCloudPlatform/colab-enterprise-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoogleCloudPlatform/colab-enterprise-vscode"
  },
  "bugs": {
    "url": "https://github.com/GoogleCloudPlatform/colab-enterprise-vscode/issues"
  },
  "qna": "https://github.com/GoogleCloudPlatform/colab-enterprise-vscode/discussions",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.103.0"
  },
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "categories": [
    "Notebooks"
  ],
  "tags": [
    "google",
    "interactive",
    "julia",
    "jupyter",
    "notebook",
    "python",
    "r"
  ],
  "activationEvents": [
    "onNotebook:jupyter-notebook",
    "onNotebook:interactive"
  ],
  "contributes": {
    "authentication": [
      {
        "label": "Google Cloud Platform",
        "id": "google-cloud-platform"
      }
    ],
    "configuration": {
      "title": "Workbench Notebooks",
      "properties": {
        "workbench-notebooks.logging.level": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug"
          ],
          "description": "Controls the verbosity of logs. These can be found in the 'Workbench Notebooks' output channel."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "clean": "rm -rf out/*",
    "generate:config": "tsx ./scripts/generate-config.mts",
    "build": "concurrently \"npm:build:extension\" \"npm:build:tests\" \"npm:typecheck\" --prefixColors=auto",
    "build:extension": "tsx esbuild.config.mts",
    "build:tests": "npm run build:extension -- --tests",
    "typecheck": "tsc --noEmit",
    "typecheck:prod": "npm run typecheck -- -p tsconfig.prod.json",
    "watch": "concurrently \"npm:watch:extension\" \"npm:watch:tests\" \"npm:watch:typecheck\" --prefixColors=auto",
    "watch:prod": "concurrently \"npm:watch:extension\" \"npm:watch:typecheck:prod\" --prefixColors=auto",
    "watch:extension": "npm run build:extension -- --watch",
    "watch:tests": "npm run build:tests -- --watch",
    "watch:typecheck": "npm run typecheck -- --watch --preserveWatchOutput",
    "watch:typecheck:prod": "npm run typecheck:prod -- --watch --preserveWatchOutput",
    "lint": "npx --node-options='--experimental-strip-types' eslint src/ scripts/ *.mts --flag unstable_native_nodejs_ts_config",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "pretest": "npm run build && npm run lint && npm run format:check && npm run typecheck",
    "test:unit": "npm run build:tests && mocha --enable-source-maps --require ./out/test/test/unit-test-setup.js './out/test/**/*.unit.test.js'",
    "test:integration": "npm run build && node ./out/test/test/integration-test-runner.js",
    "test:integration:headless": "xvfb-run -s '-screen 0 1024x768x24' npm run test:integration",
    "pretest:e2e": "npm run build:tests",
    "test:e2e": "scripts/test_e2e.sh",
    "test:e2e:headless": "npm run test:e2e -- --headless",
    "vscode:prepublish": "npm run package",
    "package": "concurrently \"npm:typecheck:prod\" \"npm:build:extension -- --production\" --prefixColors=auto"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^8.17.3",
    "@eslint/js": "^9.33.0",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/node-fetch": "^2.6.12",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^17.0.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/jupyter-extension": "1.0.93",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "clipboardy": "^4.0.0",
    "concurrently": "^9.1.2",
    "cspell": "^8.17.3",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.2",
    "esbuild-node-externals": "^1.18.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-check-file": "^3.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-license-header": "^0.8.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "mocha": "^10.8.2",
    "prettier": "3.4.2",
    "selenium-webdriver": "^4.34.0",
    "sinon": "^19.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.15.0",
    "vscode-extension-tester": "^8.14.1"
  },
  "dependencies": {
    "@google-cloud/notebooks": "^4.2.1",
    "@google-cloud/resource-manager": "^6.2.1",
    "glob": "^11.1.0",
    "google-auth-library": "^10.0.0",
    "node-fetch": "^2.6.7",
    "semver": "^7.7.3",
    "uuid": "^11.0.3",
    "zod": "^4.0.17"
  }
}
